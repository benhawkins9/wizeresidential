# Lead form email (api/lead.js) — set these in Vercel → Settings → Environment Variables.
# Only RESEND_API_KEY is required; the rest have sensible defaults.

# Required: API key from https://resend.com (after verifying oceanspringsseo.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides:
# From address (domain must be verified in Resend)
LEAD_FROM="Ocean Springs SEO <hello@oceanspringsseo.com>"
# Where new-lead notifications are sent
LEAD_NOTIFY_TO=bhawkins9@gmail.com
# Reply-to on the auto-reply the lead receives
LEAD_REPLY_TO=bhawkins9@gmail.com
