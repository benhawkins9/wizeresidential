---
import { approvedTestimonials } from "../data/testimonials";
import Icon from "./Icon.astro";
const items = approvedTestimonials;
---

{
  items.length > 0 && (
    <section class="bg-navy-50">
      <div class="container-page py-16 md:py-20">
        <div class="text-center max-w-2xl mx-auto">
          <span class="eyebrow">What clients say</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight text-navy-900">
            Trusted by Gulf Coast businesses
          </h2>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {items.map((t) => (
            <figure class="bg-white rounded-2xl p-6 shadow-sm border border-navy-100">
              <div class="flex gap-0.5 text-sand-400">
                {Array.from({ length: 5 }).map(() => (
                  <Icon name="star" class="w-4.5 h-4.5 fill-current" />
                ))}
              </div>
              <blockquote class="mt-3 text-navy-800 leading-relaxed">
                “{t.quote}”
              </blockquote>
              <figcaption class="mt-4 text-sm">
                <span class="font-semibold text-navy-900">{t.name}</span>
                <span class="text-navy-500">
                  {" "}
                  · {t.business}, {t.city}
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
