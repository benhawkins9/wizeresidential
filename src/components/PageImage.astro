---
/**
 * Renders an AI-generated page image (from src/assets/generated/<id>.png) via
 * astro:assets — optimized, responsive, lazy. Renders nothing if the image
 * doesn't exist yet, so pages stay safe before/while images are generated.
 *
 * Generate images with: node scripts/gen-fal-images.mjs  (see Image-Plan.md)
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  alt: string;
  class?: string;
  loading?: "eager" | "lazy";
  sizes?: string;
  widths?: number[];
}
const {
  id,
  alt,
  class: className,
  loading = "lazy",
  sizes = "(max-width: 768px) 100vw, 800px",
  widths = [480, 800, 1200],
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/generated/*.{png,jpg}",
  { eager: true }
);
const img = (
  images[`../assets/generated/${id}.png`] ??
  images[`../assets/generated/${id}.jpg`]
)?.default;
---

{
  img && (
    <Image
      src={img}
      alt={alt}
      class={className}
      loading={loading}
      sizes={sizes}
      widths={widths}
    />
  )
}
