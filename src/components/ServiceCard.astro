---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  icon: string;
  title: string;
  tagline: string;
  summary: string;
  price?: string;
  deliverables?: string[];
  featured?: boolean;
}
const { href, icon, title, tagline, summary, price, deliverables = [], featured = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative flex flex-col rounded-2xl p-6 border transition-all duration-200 hover:-translate-y-0.5",
    featured
      ? "bg-white border-gulf-200 shadow-sm hover:shadow-md hover:border-gulf-300"
      : "bg-white border-navy-100 shadow-sm hover:shadow-md hover:border-navy-200",
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <span
      class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gulf-50 text-gulf-600 group-hover:bg-gulf-500 group-hover:text-white transition-colors"
    >
      <Icon name={icon} class="w-6 h-6" />
    </span>
    {
      price && (
        <span class="rounded-full bg-sand-50 text-sand-800 ring-1 ring-sand-200 px-3 py-1 text-xs font-bold whitespace-nowrap">
          {price}
        </span>
      )
    }
  </div>
  <h3 class="mt-4 text-lg font-bold text-navy-900">{title}</h3>
  <p class="mt-1 text-sm font-medium text-gulf-700">{tagline}</p>
  <p class="mt-2 text-sm text-navy-600 leading-relaxed">{summary}</p>
  {
    deliverables.length > 0 && (
      <ul class="mt-3 space-y-1.5">
        {deliverables.slice(0, 3).map((d) => (
          <li class="flex items-start gap-2 text-sm text-navy-600">
            <Icon name="check" class="w-4 h-4 text-gulf-600 shrink-0 mt-0.5" />
            <span>{d}</span>
          </li>
        ))}
      </ul>
    )
  }
  <span
    class="mt-auto pt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-navy-900 group-hover:text-gulf-700"
  >
    Learn more
    <Icon name="arrow" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
  </span>
</a>
