---
import { site } from "../data/site";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import chris from "../assets/brand/chris-wise.jpg";

interface Props {
  heading?: string;
  text?: string;
  variant?: "navy" | "gulf";
}
const {
  heading = "Ready to fix it right — the first time?",
  text = "Tell me what's going on and I'll get you a fast, fair estimate. No pressure, no hidden fees — and new customers get $10 off their first service.",
  variant = "navy",
} = Astro.props;

const bg = variant === "gulf" ? "bg-gulf-700" : "bg-navy-900";
---

<section class={`${bg} text-white`}>
  <div class="container-page py-16 md:py-20">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">{heading}</h2>
      <p class="mt-4 text-lg text-white/85 leading-relaxed">{text}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/estimate" class="btn btn-primary text-base">
          Get a Free Estimate
          <Icon name="arrow" class="w-4.5 h-4.5" />
        </a>
        <a href={site.phoneHref} class="btn btn-white text-base">
          <Icon name="phone" class="w-4.5 h-4.5 text-gulf-600" />
          {site.phone}
        </a>
      </div>

      <!-- Owner: you work directly with Chris (appears on every page with a CTA) -->
      <div class="mt-9 inline-flex items-center gap-4 rounded-2xl bg-white/5 ring-1 ring-white/10 px-5 py-3.5 text-left">
        <Image
          src={chris}
          alt="Chris Wise, owner of Wise Residential"
          class="w-14 h-14 rounded-full object-cover object-top ring-2 ring-white/20 shrink-0"
          width={112}
          height={112}
        />
        <p class="text-sm text-white/85 leading-snug">
          You work directly with <strong class="text-white">Chris Wise</strong> — owner, licensed &amp; insured.
          <span class="block text-white/60">No call centers, no subcontractors. Just me.</span>
        </p>
      </div>
    </div>
  </div>
</section>
