---
/**
 * Brand lockup: the Wise Residential logo (house + "WR" mark, orange field).
 * The logo image already contains the wordmark, so it's rendered on its own.
 * The orange field reads well on both light (header) and dark (footer/hero)
 * backgrounds. `class` controls the height; the mark stays square.
 */
import { Image } from "astro:assets";
import logo from "../assets/brand/logo.jpg";

interface Props {
  class?: string;
  variant?: "default" | "white";
}
const { class: className = "h-10 w-auto" } = Astro.props;
---

<Image
  src={logo}
  alt="Wise Residential — Ocean Springs home repair & handyman"
  class={`${className} rounded-lg`}
  width={128}
  height={128}
  densities={[1, 2]}
  loading="eager"
/>
