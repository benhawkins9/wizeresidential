---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";

const nav = [
  { label: "Services", href: "/services" },
  { label: "Service Areas", href: "/locations" },
  { label: "Packages", href: "/service-packages" },
  { label: "Guides", href: "/guides" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-navy-100"
>
  <div class="container-page flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="Wise Residential home">
      <Logo class="h-10 w-auto md:h-12" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-[0.95rem] font-medium link-underline transition-colors",
              isActive(item.href)
                ? "text-gulf-700"
                : "text-navy-700 hover:text-navy-900",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:flex items-center gap-4">
      <a
        href={site.phoneHref}
        class="flex items-center gap-2 text-navy-800 font-semibold hover:text-gulf-700"
      >
        <Icon name="phone" class="w-4.5 h-4.5 text-gulf-600" />
        <span>{site.phone}</span>
      </a>
      <a href="/estimate" class="btn btn-primary text-sm">Free Estimate</a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg text-navy-800 hover:bg-navy-50"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-navy-100 bg-white">
    <nav class="container-page py-4 flex flex-col gap-1" aria-label="Mobile">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "py-2.5 px-2 rounded-lg text-base font-medium",
              isActive(item.href)
                ? "text-gulf-700 bg-gulf-50"
                : "text-navy-800 hover:bg-navy-50",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={site.phoneHref}
        class="mt-2 flex items-center gap-2 py-2.5 px-2 font-semibold text-navy-900"
      >
        <Icon name="phone" class="w-5 h-5 text-gulf-600" />
        {site.phone}
      </a>
      <a href="/estimate" class="btn btn-primary mt-1">Get a Free Estimate</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
    btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
