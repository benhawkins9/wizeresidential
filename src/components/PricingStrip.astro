---
/**
 * Consistent pricing band shown on service + location pages so pricing is
 * visible across the board. Dark navy card with orange figures — pops on the
 * gray page background. Full breakdown lives on /service-packages.
 */
import Icon from "./Icon.astro";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const facts = [
  { big: "$90", small: "service visit — covers travel, setup & your first 1¼ hours of work" },
  { big: "Flat-rate", small: "written estimates for bigger jobs, discounted from standard rates" },
  { big: "From $18/mo", small: "water-filtration maintenance plans" },
];
---

<section class={className}>
  <div class="container-page py-10 md:py-12">
    <div class="rounded-3xl bg-navy-900 text-white p-7 md:p-9">
      <div class="flex flex-col lg:flex-row lg:items-center gap-7 lg:gap-10 justify-between">
        <div class="grid sm:grid-cols-3 gap-6 flex-1">
          {
            facts.map((f) => (
              <div>
                <p class="text-2xl md:text-3xl font-extrabold text-sand-400">{f.big}</p>
                <p class="mt-1 text-sm text-navy-200 leading-snug">{f.small}</p>
              </div>
            ))
          }
        </div>
        <a href="/service-packages" class="btn btn-primary shrink-0">
          See full pricing <Icon name="arrow" class="w-4.5 h-4.5" />
        </a>
      </div>
      <p class="mt-6 pt-5 border-t border-white/10 text-xs text-navy-400">
        One fair price regardless of your zip code · materials billed separately if needed · no hidden fees · $10 off your first service.
      </p>
    </div>
  </div>
</section>
