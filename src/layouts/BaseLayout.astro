---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import {
  websiteSchema,
  localBusinessSchema,
  personSchema,
} from "../lib/schema";

interface Props {
  title: string;
  description: string;
  /** Path only, e.g. "/services/local-seo". Defaults to current URL. */
  canonicalPath?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  /** Extra JSON-LD objects to inject (page-specific schema). */
  schema?: unknown[];
}

const {
  title,
  description,
  canonicalPath,
  ogImage = "/og-image.png",
  ogType = "website",
  noindex = false,
  schema = [],
} = Astro.props;

const canonical = new URL(canonicalPath ?? Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(ogImage, site.url).href;
const fullTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;

// Global schema graph present on every page, plus page-specific schema.
const allSchema = [
  websiteSchema(),
  localBusinessSchema(),
  personSchema(),
  ...schema,
].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Icons / theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#e8740f" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Preconnect for fonts (self-host later for full control — see REVIEW) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    {
      allSchema.map((s) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(s)}
        />
      ))
    }

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-3 focus:left-3 focus:bg-white focus:text-navy-900 focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg"
      >Skip to content</a
    >
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
