---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Icon from "../../components/Icon.astro";
import PageImage from "../../components/PageImage.astro";
import { site } from "../../data/site";
import {
  serviceSchema,
  faqSchema,
  breadcrumbSchema,
} from "../../lib/schema";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// Related services (everything else, by order)
const related = (await getCollection("services"))
  .filter((s) => s.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const url = `${site.url}/services/${entry.id}`;
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Services", url: "/services" },
  { name: data.shortTitle, url: `/services/${entry.id}` },
];

const schema = [
  serviceSchema({ name: data.title, description: data.summary, url }),
  faqSchema(data.faqs),
  breadcrumbSchema(crumbs),
].filter(Boolean);
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  canonicalPath={`/services/${entry.id}`}
  ogType="article"
  schema={schema}
>
  <Breadcrumbs crumbs={crumbs} />

  <!-- Hero -->
  <section class="container-page pt-8 pb-10 md:pt-10">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
      <span class="inline-flex items-center gap-2 text-gulf-600">
        <span class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-gulf-50">
          <Icon name={data.icon} class="w-6 h-6" />
        </span>
        <span class="eyebrow">Service</span>
      </span>
      <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
        {data.title}
      </h1>
      <p class="mt-4 text-xl text-gulf-700 font-medium">{data.tagline}</p>
      <p class="mt-3 text-lg text-navy-600 leading-relaxed">{data.summary}</p>
      <div class="mt-7 flex flex-col sm:flex-row gap-3">
        <a href="/estimate" class="btn btn-primary">Get a Free Estimate <Icon name="arrow" class="w-4.5 h-4.5" /></a>
        <a href={site.phoneHref} class="btn btn-ghost">
          <Icon name="phone" class="w-4.5 h-4.5 text-gulf-600" /> {site.phone}
        </a>
      </div>
      </div>
      <PageImage id={`service-${entry.id}`} alt={`${data.title}`} class="w-full rounded-2xl shadow-sm border border-navy-100" loading="eager" widths={[400, 600, 800]} sizes="(max-width: 1024px) 100vw, 480px" />
    </div>
  </section>

  <!-- Outcomes -->
  {
    data.outcomes.length > 0 && (
      <section class="container-page pb-4">
        <div class="grid sm:grid-cols-2 gap-4">
          {data.outcomes.map((o) => (
            <div class="flex items-start gap-3 rounded-xl bg-navy-50 p-4">
              <Icon name="check-circle" class="w-5.5 h-5.5 text-gulf-600 shrink-0 mt-0.5" />
              <span class="text-navy-800">{o}</span>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Body + sidebar -->
  <section class="container-page py-12 md:py-16">
    <div class="grid lg:grid-cols-3 gap-10">
      <article class="lg:col-span-2 prose-local max-w-none">
        <Content />
      </article>

      <aside class="lg:col-span-1 space-y-6">
        {
          data.deliverables.length > 0 && (
            <div class="rounded-2xl border border-navy-100 bg-white p-6 shadow-sm">
              <h2 class="text-base font-bold text-navy-900">What's included</h2>
              <ul class="mt-4 space-y-2.5">
                {data.deliverables.map((d) => (
                  <li class="flex items-start gap-2.5 text-sm text-navy-700">
                    <Icon name="check" class="w-4.5 h-4.5 text-gulf-600 shrink-0 mt-0.5" />
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div class="rounded-2xl bg-navy-900 text-white p-6 shadow-sm">
          <h2 class="text-base font-bold">Start with a free estimate</h2>
          <p class="mt-2 text-sm text-navy-200">
            Tell me about your {data.shortTitle.toLowerCase()} job and I'll get you a fast, fair quote — and new customers get $10 off their first service.
          </p>
          <p class="mt-4 text-sm">
            <a href="/service-packages" class="text-gulf-300 underline underline-offset-2 hover:text-white">See service packages →</a>
          </p>
          <a href="/estimate" class="btn btn-primary w-full mt-4">Get a Free Estimate</a>
        </div>
      </aside>
    </div>
  </section>

  <FAQ faqs={data.faqs} heading={`${data.shortTitle}: common questions`} />

  <!-- Related services -->
  <section class="bg-sand-wash">
    <div class="container-page py-16">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-navy-900 text-center">
        Related services
      </h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {
          related.map((s) => (
            <a
              href={`/services/${s.id}`}
              class="group rounded-2xl bg-white border border-navy-100 p-5 shadow-sm hover:shadow-md hover:border-gulf-200 transition-all"
            >
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-gulf-50 text-gulf-600">
                <Icon name={s.data.icon} class="w-5 h-5" />
              </span>
              <h3 class="mt-3 font-bold text-navy-900 group-hover:text-gulf-700">
                {s.data.shortTitle}
              </h3>
              <p class="mt-1 text-sm text-navy-600">{s.data.tagline}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
