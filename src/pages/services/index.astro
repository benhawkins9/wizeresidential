---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import PricingStrip from "../../components/PricingStrip.astro";
import CTASection from "../../components/CTASection.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Icon from "../../components/Icon.astro";
import { breadcrumbSchema } from "../../lib/schema";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Services", url: "/services" },
];

const chips = [
  "Licensed & insured",
  "From $90 / visit",
  "Free estimates",
  "$10 off your first service",
];
---

<BaseLayout
  title="Home Repair & Handyman Services in Ocean Springs, MS"
  description="Wise Residential's services: small-job handyman work, mold remediation, water filtration, drywall & painting, carpentry & wood rot, door & window repair, kitchen & bath, and gutters — across Ocean Springs and the MS Gulf Coast."
  canonicalPath="/services"
  schema={[breadcrumbSchema(crumbs)]}
>
  <Breadcrumbs crumbs={crumbs} />

  <!-- Hero -->
  <section class="container-page pt-8 pb-10 md:pt-12">
    <div class="max-w-3xl">
      <span class="eyebrow">Services</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
        Home repair &amp; handyman services on the Gulf Coast
      </h1>
      <p class="mt-5 text-lg text-navy-600 leading-relaxed">
        One trusted, licensed local pro for the whole house — from the small jobs
        nobody else will take to the specialized work that keeps a coastal home
        healthy. Pick what you need, or hand me the list.
      </p>
      <div class="mt-7 flex flex-col sm:flex-row gap-3">
        <a href="/estimate" class="btn btn-primary">Get a Free Estimate <Icon name="arrow" class="w-4.5 h-4.5" /></a>
        <a href={"/contact"} class="btn btn-ghost">Talk to Chris</a>
      </div>
      <div class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-navy-600">
        {
          chips.map((c) => (
            <span class="inline-flex items-center gap-2">
              <Icon name="check-circle" class="w-4.5 h-4.5 text-gulf-600" />
              {c}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <PricingStrip />

  <!-- Service cards -->
  <section class="container-page py-12 md:py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 items-stretch">
      {
        services.map((s) => (
          <ServiceCard
            href={`/services/${s.id}`}
            icon={s.data.icon}
            title={s.data.shortTitle}
            tagline={s.data.tagline}
            summary={s.data.summary}
            price={s.data.priceFrom}
            deliverables={s.data.deliverables}
            featured={s.data.featured}
          />
        ))
      }
    </div>
  </section>

  <CTASection variant="gulf" />
</BaseLayout>
