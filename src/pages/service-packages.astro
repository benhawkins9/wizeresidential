---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import FAQ from "../components/FAQ.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Icon from "../components/Icon.astro";
import { breadcrumbSchema, faqSchema } from "../lib/schema";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Service Packages", url: "/service-packages" },
];

// Labor packages — matches the live site's pricing model.
const packages = [
  {
    name: "Service Visit",
    price: "$90",
    unit: "per visit",
    tagline: "The simplest way to get on the schedule.",
    highlight: false,
    features: [
      "Covers travel, setup & your first 1 hr 15 min of work",
      "Perfect for a quick fix or a couple of small jobs",
      "Anything beyond is a flat-rate estimate",
      "One fair price — same rate, any zip code",
    ],
    note: "Materials billed separately if needed.",
    cta: { label: "Book a visit", href: "/estimate" },
  },
  {
    name: "Half-Day · 4 hours",
    price: "Flat-rate",
    unit: "estimate",
    tagline: "Great for knocking out 3–5 small jobs in one trip.",
    highlight: true,
    features: [
      "Clear a to-do list in a single visit",
      "Flat-rate labor, discounted from standard rates",
      "Ideal for a punch list or several repairs",
      "Materials billed separately if needed",
    ],
    note: "Estimate based — I quote it before we start.",
    cta: { label: "Get a free estimate", href: "/estimate" },
  },
  {
    name: "Full-Day · 8 hours",
    price: "Flat-rate",
    unit: "estimate",
    tagline: "Clear the whole list, or tackle a bigger project.",
    highlight: false,
    features: [
      "A full day of focused work on your home",
      "Best per-hour value for long to-do lists",
      "Flat-rate labor, discounted from standard rates",
      "Great for seasonal catch-up or move-in prep",
    ],
    note: "Estimate based — quoted up front.",
    cta: { label: "Get a free estimate", href: "/contact" },
  },
];

// Real published water-filtration maintenance pricing (from the live site).
const wholeHome = [
  { freq: "1× / year", price: "$150", save: "" },
  { freq: "2× / year (recommended)", price: "$260", save: "save $40" },
  { freq: "4× / year", price: "$520", save: "save $80" },
];
const underSink = [
  { freq: "1× / year", price: "$125", save: "" },
  { freq: "2× / year (recommended)", price: "$210", save: "save $40" },
  { freq: "4× / year", price: "$380", save: "save $120" },
];
const monthly = [
  { plan: "Whole-home · 2×/yr", price: "$22/mo" },
  { plan: "Whole-home · 4×/yr", price: "$45/mo" },
  { plan: "Under-sink / RO · 2×/yr", price: "$18/mo" },
  { plan: "Under-sink / RO · 4×/yr", price: "$32/mo" },
];
const visitIncludes = [
  "Filter swap(s)",
  "Housing sanitization",
  "Pressure/flow + leak checks",
  "Bypass/valve check",
  "Basic water-quality test",
  "Service log + next-visit reminders",
];

const packageFaqs = [
  {
    q: "How does the $90 service visit work?",
    a: "Your $90 service visit covers travel, setup, and up to the first hour and 15 minutes of work — perfect for a quick fix or a couple of small jobs. Anything beyond that is quoted as a flat-rate estimate I give you before any extra work begins.",
  },
  {
    q: "What are the half-day and full-day packages?",
    a: "The half-day is a 4-hour block (great for 3–5 small jobs), and the full-day is 8 hours for a long to-do list or a bigger project. Both are flat-rate labor, discounted from my standard rates, with materials billed separately if needed.",
  },
  {
    q: "How much does water-filtration maintenance cost?",
    a: "Whole-home plans run $150–$520/year depending on frequency (or $22–$45/month); under-sink/RO plans are $125–$380/year (or $18–$32/month). Each visit includes filter swaps, sanitizing, leak checks, and a basic water-quality test. Filters, membranes, and UV bulbs are billed at current market pricing.",
  },
  {
    q: "Do you offer custom maintenance plans?",
    a: "Yes. For ongoing seasonal upkeep, post-inspection punch lists, or mold aftercare, I'll build a simple plan around your home with straightforward terms — created on a client-to-client basis.",
  },
  {
    q: "Are estimates really discounted?",
    a: "Yes — the estimates I provide are discounted down from my standard rates, and I'll always show you the flat-rate price before any work starts. No hidden fees.",
  },
];
---

<BaseLayout
  title="Service Packages & Pricing | Wise Residential Ocean Springs"
  description="Wise Residential pricing for Ocean Springs, MS — a $90 service visit, flat-rate half-day & full-day labor blocks, and water-filtration maintenance plans from $18/mo. Free estimates, fair pricing."
  canonicalPath="/service-packages"
  schema={[breadcrumbSchema(crumbs), faqSchema(packageFaqs)]}
>
  <Breadcrumbs crumbs={crumbs} />

  <!-- Hero -->
  <section class="container-page pt-8 pb-10 md:pt-12 text-center">
    <span class="eyebrow">Service Packages &amp; Pricing</span>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
      Simple, flat-rate, fair pricing
    </h1>
    <p class="mt-5 text-lg text-navy-600 leading-relaxed max-w-2xl mx-auto">
      Start with a $90 service visit, book a discounted half- or full-day block
      for a bigger list, or put your water filtration on a maintenance plan. One
      fair price no matter your zip code — and estimates discounted from my
      standard rates.
    </p>
    <div class="mt-6 inline-flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm text-navy-600">
      <span class="inline-flex items-center gap-2"><Icon name="check-circle" class="w-4.5 h-4.5 text-gulf-600" /> Free estimates</span>
      <span class="inline-flex items-center gap-2"><Icon name="check-circle" class="w-4.5 h-4.5 text-gulf-600" /> Flat-rate labor</span>
      <span class="inline-flex items-center gap-2"><Icon name="check-circle" class="w-4.5 h-4.5 text-gulf-600" /> $10 off your first service</span>
    </div>
  </section>

  <!-- Labor packages -->
  <section class="container-page py-10">
    <div class="grid gap-6 lg:grid-cols-3">
      {
        packages.map((p) => (
          <div
            class:list={[
              "relative flex flex-col rounded-2xl border p-7 shadow-sm bg-white",
              p.highlight ? "border-gulf-300 ring-1 ring-gulf-200" : "border-navy-100",
            ]}
          >
            {p.highlight && (
              <span class="absolute -top-3 left-7 rounded-full bg-sand-400 text-navy-950 text-xs font-bold px-3 py-1">
                Most popular
              </span>
            )}
            <h2 class="text-xl font-bold text-navy-900">{p.name}</h2>
            <p class="mt-1 text-sm text-navy-600">{p.tagline}</p>
            <div class="mt-4 flex items-baseline gap-1.5">
              <span class="text-3xl font-extrabold text-navy-900">{p.price}</span>
              <span class="text-navy-500">{p.unit}</span>
            </div>
            <ul class="mt-5 space-y-2.5 flex-1">
              {p.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-navy-700">
                  <Icon name="check" class="w-4.5 h-4.5 text-gulf-600 shrink-0 mt-0.5" />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            {p.note && <p class="mt-4 text-xs text-navy-500 italic">{p.note}</p>}
            <a href={p.cta.href} class:list={["btn mt-5 w-full", p.highlight ? "btn-primary" : "btn-ghost"]}>
              {p.cta.label} <Icon name="arrow" class="w-4.5 h-4.5" />
            </a>
          </div>
        ))
      }
    </div>
    <p class="mt-6 text-sm text-navy-500 text-center max-w-2xl mx-auto">
      Bigger projects — mold remediation, carpentry, renovations, filtration installs — are quoted individually as flat-rate estimates. Materials billed separately if needed.
    </p>
  </section>

  <!-- Water filtration maintenance plans -->
  <section class="bg-sand-wash">
    <div class="container-page py-14 md:py-16">
      <div class="max-w-2xl">
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-navy-900">Water filtration maintenance plans</h2>
        <p class="mt-2 text-navy-600">Set terms, real prices — keep your system clean and efficient without thinking about it. I service my own installs and existing systems from any installer.</p>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <!-- Whole-home -->
        <div class="rounded-2xl bg-white border border-navy-100 p-6 shadow-sm">
          <h3 class="font-bold text-navy-900 flex items-center gap-2"><Icon name="droplet" class="w-5 h-5 text-gulf-600" /> Whole-home systems</h3>
          <table class="mt-4 w-full text-sm">
            <tbody>
              {wholeHome.map((r) => (
                <tr class="border-b border-navy-50 last:border-0">
                  <td class="py-2.5 text-navy-700">{r.freq}</td>
                  <td class="py-2.5 text-right font-bold text-navy-900">{r.price}</td>
                  <td class="py-2.5 text-right text-gulf-700 text-xs w-20">{r.save}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <!-- Under-sink / RO -->
        <div class="rounded-2xl bg-white border border-navy-100 p-6 shadow-sm">
          <h3 class="font-bold text-navy-900 flex items-center gap-2"><Icon name="droplet" class="w-5 h-5 text-gulf-600" /> Under-sink / RO systems</h3>
          <table class="mt-4 w-full text-sm">
            <tbody>
              {underSink.map((r) => (
                <tr class="border-b border-navy-50 last:border-0">
                  <td class="py-2.5 text-navy-700">{r.freq}</td>
                  <td class="py-2.5 text-right font-bold text-navy-900">{r.price}</td>
                  <td class="py-2.5 text-right text-gulf-700 text-xs w-20">{r.save}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl bg-white border border-navy-100 p-6 shadow-sm">
          <h3 class="text-sm font-bold uppercase tracking-wider text-navy-500">Prefer monthly?</h3>
          <ul class="mt-3 grid sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
            {monthly.map((m) => (
              <li class="flex items-center justify-between gap-3 border-b border-navy-50 pb-1.5">
                <span class="text-navy-700">{m.plan}</span>
                <span class="font-bold text-navy-900">{m.price}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl bg-white border border-navy-100 p-6 shadow-sm">
          <h3 class="text-sm font-bold uppercase tracking-wider text-navy-500">Every visit includes</h3>
          <ul class="mt-3 grid sm:grid-cols-2 gap-x-6 gap-y-2">
            {visitIncludes.map((v) => (
              <li class="flex items-start gap-2 text-sm text-navy-700">
                <Icon name="check" class="w-4 h-4 text-gulf-600 shrink-0 mt-0.5" /> <span>{v}</span>
              </li>
            ))}
          </ul>
          <p class="mt-3 text-xs text-navy-500 italic">Filters, membranes, UV bulbs &amp; media billed at current market pricing.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQ faqs={packageFaqs} heading="Pricing questions" />

  <CTASection
    heading="Not sure what you need?"
    text="Tell me about your home and your list. I'll recommend the simplest, fairest way to get it handled — and apply your $10 new-customer credit."
  />
</BaseLayout>
