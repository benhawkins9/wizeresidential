---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Icon from "../components/Icon.astro";
import { locations } from "../data/locations";
import { site } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Sitemap", url: "/sitemap" },
];

const groups = [
  {
    title: "Main pages",
    icon: "browser",
    links: [
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Service Areas", href: "/locations" },
      { label: "Service Packages", href: "/service-packages" },
      { label: "Guides", href: "/guides" },
      { label: "About Chris", href: "/about" },
      { label: "Reviews", href: "/results" },
      { label: "Free Estimate", href: "/estimate" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Services",
    icon: "wrench",
    links: services.map((s) => ({
      label: s.data.title,
      href: `/services/${s.id}`,
    })),
  },
  {
    title: "Service areas",
    icon: "map",
    links: [
      { label: "Ocean Springs (home)", href: "/" },
      ...locations.map((l) => ({
        label: `Handyman in ${l.name}`,
        href: `/locations/${l.slug}`,
      })),
    ],
  },
  {
    title: "Legal",
    icon: "doc",
    links: [
      { label: "Privacy Policy", href: "/privacy" },
      { label: "Terms & Conditions", href: "/terms" },
      { label: "Accessibility", href: "/accessibility" },
    ],
  },
];
---

<BaseLayout
  title="Sitemap"
  description="A complete map of wizeresidential.com — every home-repair service, Gulf Coast service area, and page, in one place."
  canonicalPath="/sitemap"
  schema={[breadcrumbSchema(crumbs)]}
>
  <Breadcrumbs crumbs={crumbs} />

  <section class="container-page pt-8 pb-16 md:pt-12">
    <div class="max-w-3xl">
      <span class="eyebrow">Sitemap</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
        Everything on {site.domain}
      </h1>
      <p class="mt-5 text-lg text-navy-600 leading-relaxed">
        A full map of the site — every service, Gulf Coast service area, and page,
        all in one place. Looking for something specific? It's linked below.
      </p>
    </div>

    <div class="mt-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        groups.map((g) => (
          <div>
            <h2 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-navy-500">
              <Icon name={g.icon} class="w-4.5 h-4.5 text-gulf-600" />
              {g.title}
            </h2>
            <ul class="mt-4 space-y-2.5">
              {g.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="text-navy-700 hover:text-gulf-700 link-underline"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="mt-12 pt-6 border-t border-navy-100 text-sm text-navy-500">
      Search engines: the XML sitemap is at
      <a href="/sitemap-index.xml" class="text-gulf-700 link-underline">/sitemap-index.xml</a>.
    </p>
  </section>
</BaseLayout>
