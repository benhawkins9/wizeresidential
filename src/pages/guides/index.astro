---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Icon from "../../components/Icon.astro";
import { webPageSchema, breadcrumbSchema } from "../../lib/schema";

const guides = (await getCollection("guides")).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Guides", url: "/guides" },
];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout
  title="Home Repair & Coastal-Home Guides | Wise Residential"
  description="Practical home-repair guides for Gulf Coast homeowners — mold prevention, water quality, wood rot, storm prep, and hiring a handyman. From Chris Wise at Wise Residential."
  canonicalPath="/guides"
  schema={[
    webPageSchema("CollectionPage", {
      name: "Guides",
      url: "/guides",
      description: "Home-repair and coastal-home maintenance guides for Gulf Coast homeowners.",
    }),
    breadcrumbSchema(crumbs),
  ]}
>
  <Breadcrumbs crumbs={crumbs} />

  <section class="container-page pt-8 pb-10 md:pt-12">
    <div class="max-w-3xl">
      <span class="eyebrow">Guides</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
        Coastal-home know-how, in plain English
      </h1>
      <p class="mt-5 text-lg text-navy-600 leading-relaxed">
        No jargon — just straight answers from a licensed local contractor on
        keeping a Gulf Coast home healthy: mold, water quality, wood rot, storm
        prep, and how to hire the right help.
      </p>
    </div>
  </section>

  <section class="container-page pb-16">
    {
      guides.length === 0 ? (
        <p class="text-navy-500">New guides are coming soon.</p>
      ) : (
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {guides.map((g) => (
            <a
              href={`/guides/${g.id}`}
              class="group flex flex-col rounded-2xl bg-white border border-navy-100 p-6 shadow-sm hover:shadow-md hover:border-gulf-200 hover:-translate-y-0.5 transition-all"
            >
              <span class="text-xs font-bold uppercase tracking-wide text-gulf-600">
                {g.data.category}
              </span>
              <h2 class="mt-2 text-lg font-bold text-navy-900 group-hover:text-gulf-700">
                {g.data.title}
              </h2>
              <p class="mt-2 text-sm text-navy-600 leading-relaxed flex-1">
                {g.data.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-navy-900 group-hover:text-gulf-700">
                Read guide
                <Icon name="arrow" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <CTASection variant="gulf" />
</BaseLayout>
