---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTASection from "../../../components/CTASection.astro";
import OnTimePromise from "../../../components/OnTimePromise.astro";
import PricingStrip from "../../../components/PricingStrip.astro";
import FAQ from "../../../components/FAQ.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Icon from "../../../components/Icon.astro";
import OwnerHero from "../../../components/OwnerHero.astro";
import { locations, resolveNearby } from "../../../data/locations";
import { site } from "../../../data/site";
import { serviceSchema, faqSchema, breadcrumbSchema } from "../../../lib/schema";

/**
 * Programmatic [service] × [city] pages — the local-intent matrix.
 * Each page is a UNIQUE combination of a city's real local detail (landmarks,
 * market note, drive time) and a service's real scope (deliverables, summary),
 * so it targets "[service] in [city]" + "[service] near me" without being thin.
 */
export async function getStaticPaths() {
  const services = (await getCollection("services")).sort(
    (a, b) => a.data.order - b.data.order
  );
  return locations.flatMap((loc) =>
    services.map((service) => ({
      params: { city: loc.slug, service: service.id },
      props: { loc, service, services },
    }))
  );
}

const { loc, service, services } = Astro.props;
const d = service.data;
const lower = d.shortTitle.toLowerCase();
const url = `${site.url}/locations/${loc.slug}/${service.id}`;

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Service Areas", url: "/locations" },
  { name: loc.name, url: `/locations/${loc.slug}` },
  { name: d.shortTitle, url: `/locations/${loc.slug}/${service.id}` },
];

const faqs = [
  {
    q: `How soon can you get to ${loc.name} for ${lower}?`,
    a: `Usually within 24–48 hours. I'm based in Ocean Springs, just ${loc.driveTime} from ${loc.name}, so local ${lower} calls are easy to reach — and you get the same fair price no matter where in town you are. ${d.summary}`,
  },
  {
    q: `How do I get an estimate for ${lower} in ${loc.name}?`,
    a: `Call or text me, or send a few photos — ${loc.name} homeowners can often get a ballpark fast. You'll get a written estimate at one fair price (the same no matter your zip code), plus $10 off your first service.`,
  },
  {
    q: `Are you licensed and insured to work in ${loc.name}?`,
    a: `Absolutely — Wise Residential is fully licensed (MS #1500778) and insured for ${lower} and all home-repair work across ${loc.county} and the Mississippi Gulf Coast.`,
  },
];

const otherServices = services.filter((s) => s.id !== service.id).slice(0, 5);
const nearbyLinks = loc.nearby
  .map((slug) => resolveNearby(slug))
  .filter((x): x is { name: string; href: string } => Boolean(x));

const schema = [
  serviceSchema({
    name: `${d.shortTitle} in ${loc.name}, ${site.baseRegion}`,
    description: `${d.shortTitle} in ${loc.name}, MS — ${d.summary}`,
    url,
  }),
  faqSchema(faqs),
  breadcrumbSchema(crumbs),
].filter(Boolean);
---

<BaseLayout
  title={`${d.shortTitle} in ${loc.name}, MS | Near Me`}
  description={`${d.shortTitle} in ${loc.name}, MS — licensed, insured ${lower} from Wise Residential. ${loc.name} homeowners get a free estimate + $10 off the first service.`}
  canonicalPath={`/locations/${loc.slug}/${service.id}`}
  ogType="article"
  schema={schema}
>
  <Breadcrumbs crumbs={crumbs} />

  <!-- Hero -->
  <section class="container-page pt-8 pb-10 md:pt-10">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-gulf-50 text-gulf-700 px-3 py-1 text-xs font-semibold">
          <Icon name="pin" class="w-4 h-4" />
          {loc.name} · {loc.county}
        </span>
        <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
          {d.shortTitle} in {loc.name}
        </h1>
        <p class="mt-4 text-xl md:text-2xl font-bold text-navy-900 text-balance">{d.problemHook ?? d.tagline}</p>
        <p class="mt-3 text-lg text-navy-600 leading-relaxed">
          Looking for {lower} near you in {loc.name}? {d.summary} I'm just {loc.driveTime} away in Ocean Springs and treat every {loc.name} home the same way — on time, one fair price, and left cleaner than I found it.
        </p>
        <div class="mt-5 inline-flex items-center gap-2 rounded-full bg-sand-50 text-sand-800 ring-1 ring-sand-200 px-4 py-1.5 text-sm font-bold">
          <Icon name="check-circle" class="w-4 h-4" /> {d.priceFrom}
        </div>
        <div class="mt-7 flex flex-col sm:flex-row gap-3">
          <a href="/estimate" class="btn btn-primary">Free {loc.name} Estimate <Icon name="arrow" class="w-4.5 h-4.5" /></a>
          <a href={site.phoneHref} class="btn btn-ghost">
            <Icon name="phone" class="w-4.5 h-4.5 text-gulf-600" /> Call me today
          </a>
        </div>
      </div>
      <div>
        <OwnerHero caption={`Your ${loc.name} handyman`} />
      </div>
    </div>
  </section>

  <!-- Why here -->
  <section class="container-page py-10">
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-navy-900">
          Why {loc.name} homeowners choose Wise Residential for {lower}
        </h2>
        <p class="mt-4 text-lg text-navy-600 leading-relaxed">{loc.marketNote}</p>
        <p class="mt-4 text-navy-600 leading-relaxed">
          From homes near {loc.landmarks[0]} to {loc.landmarks[1]}, I bring licensed,
          insured {lower} to {loc.name} — and because I'm a local repair contractor,
          not a single-trick crew, I catch the related problems others miss.
          <a href={`/services/${service.id}`} class="text-gulf-700 link-underline">Learn more about {lower} →</a>
        </p>
      </div>
      {
        d.deliverables.length > 0 && (
          <div class="rounded-2xl border border-navy-100 bg-white p-6 shadow-sm">
            <h3 class="text-base font-bold text-navy-900">What's included</h3>
            <ul class="mt-4 space-y-2.5">
              {d.deliverables.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-navy-700">
                  <Icon name="check" class="w-4.5 h-4.5 text-gulf-600 shrink-0 mt-0.5" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </section>

  <OnTimePromise />

  <!-- Other services in this city -->
  <section class="bg-sand-wash">
    <div class="container-page py-14">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-navy-900">
        Other services in {loc.name}
      </h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          otherServices.map((s) => (
            <a
              href={`/locations/${loc.slug}/${s.id}`}
              class="group rounded-2xl bg-white border border-navy-100 p-5 shadow-sm hover:shadow-md hover:border-gulf-200 transition-all"
            >
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-gulf-50 text-gulf-600 group-hover:bg-gulf-500 group-hover:text-white transition-colors">
                <Icon name={s.data.icon} class="w-5 h-5" />
              </span>
              <h3 class="mt-3 font-bold text-navy-900 group-hover:text-gulf-700">
                {s.data.shortTitle}
              </h3>
              <p class="mt-1 text-sm text-navy-600">{s.data.tagline}</p>
            </a>
          ))
        }
      </div>
      <p class="mt-6 text-sm text-navy-600">
        See everything for this city on the <a href={`/locations/${loc.slug}`} class="text-gulf-700 link-underline">{loc.name} home-repair page</a>.
      </p>
    </div>
  </section>

  <!-- Nearby -->
  {
    nearbyLinks.length > 0 && (
      <section class="container-page py-8">
        <div class="rounded-2xl border border-navy-100 bg-white p-6 shadow-sm">
          <h2 class="text-sm font-bold uppercase tracking-wider text-navy-500">
            {d.shortTitle} in nearby areas
          </h2>
          <div class="mt-3 flex flex-wrap gap-2.5">
            {nearbyLinks.map((n) => (
              <a
                href={n.href === "/" ? "/" : `${n.href}/${service.id}`}
                class="inline-flex items-center gap-1.5 rounded-full bg-navy-50 hover:bg-gulf-50 text-navy-800 hover:text-gulf-700 px-4 py-2 text-sm font-medium transition-colors"
              >
                <Icon name="pin" class="w-4 h-4" />
                {n.name}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <PricingStrip />

  <FAQ faqs={faqs} heading={`${d.shortTitle} in ${loc.name}: common questions`} />

  <CTASection heading={`Need ${lower} in ${loc.name}? Let's get it done.`} />
</BaseLayout>
