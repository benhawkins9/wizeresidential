---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocationCard from "../../components/LocationCard.astro";
import CTASection from "../../components/CTASection.astro";
import OnTimePromise from "../../components/OnTimePromise.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Icon from "../../components/Icon.astro";
import { locations } from "../../data/locations";
import { site } from "../../data/site";
import { breadcrumbSchema } from "../../lib/schema";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Service Areas", url: "/locations" },
];

// Group by county for a scannable layout.
const byCounty = locations.reduce<Record<string, typeof locations>>(
  (acc, l) => {
    (acc[l.county] ??= []).push(l);
    return acc;
  },
  {}
);
---

<BaseLayout
  title="Service Areas | Handyman & Home Repair on the MS Gulf Coast"
  description="Wise Residential serves Ocean Springs and the surrounding coast — Gautier, St. Martin, Gulf Hills, Biloxi, D'Iberville, Vancleave, Moss Point & Pascagoula. Find your city for a free estimate."
  canonicalPath="/locations"
  schema={[breadcrumbSchema(crumbs)]}
>
  <Breadcrumbs crumbs={crumbs} />

  <section class="container-page pt-8 pb-12 md:pt-12">
    <div class="max-w-3xl">
      <span class="eyebrow">Service Areas</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-navy-900">
        Home repair across the Mississippi Gulf Coast
      </h1>
      <p class="mt-5 text-lg text-navy-600 leading-relaxed">
        I'm based in Ocean Springs and I serve this coast — Jackson and Harrison
        County, a short drive from home. Find your city below, or
        <a href="/contact" class="text-gulf-700 link-underline">reach out</a> if you're
        nearby and don't see it listed.
      </p>
      <div class="mt-7">
        <a href="/estimate" class="btn btn-primary">Get a Free Estimate <Icon name="arrow" class="w-4.5 h-4.5" /></a>
      </div>
    </div>
  </section>

  <OnTimePromise />

  <!-- Home city callout -->
  <section class="container-page pb-6">
    <a
      href="/"
      class="group flex flex-col sm:flex-row sm:items-center gap-4 justify-between rounded-2xl bg-navy-900 text-white p-6 md:p-8"
    >
      <div class="flex items-start gap-4">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-white/10 text-sand-300 shrink-0">
          <Icon name="pin" class="w-6 h-6" />
        </span>
        <div>
          <h2 class="text-xl font-bold">Ocean Springs, MS — my home base</h2>
          <p class="mt-1 text-navy-200">
            {site.baseCity} is where I live and work. It's the heart of everything I do.
          </p>
        </div>
      </div>
      <span class="btn btn-white shrink-0">Ocean Springs handyman <Icon name="arrow" class="w-4 h-4" /></span>
    </a>
  </section>

  {
    Object.entries(byCounty).map(([county, cities]) => (
      <section class="container-page py-8">
        <h2 class="text-sm font-bold uppercase tracking-wider text-navy-500 mb-5">
          {county}
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {cities.map((c) => (
            <LocationCard
              href={`/locations/${c.slug}`}
              name={c.name}
              county={c.county}
              driveTime={c.driveTime}
              blurb={c.blurb}
            />
          ))}
        </div>
      </section>
    ))
  }

  <div class="py-8"></div>
  <CTASection variant="gulf" />
</BaseLayout>
